# Installed by Keyboard Concert.
# Grants the seated (active) user raw HID access to Logitech receivers/devices,
# which Keyboard Concert needs to send HID++ lighting commands. Replaces Solaar's
# 42-logitech-unify-permissions.rules after the solaar package is removed.

ACTION=="remove", GOTO="kc_end"
SUBSYSTEM!="hidraw", GOTO="kc_end"

# USB-connected Logitech receivers and devices
ATTRS{idVendor}=="046d", GOTO="kc_apply"
# Bluetooth-connected Logitech devices
KERNELS=="0005:046D:*", GOTO="kc_apply"
GOTO="kc_end"

LABEL="kc_apply"
TAG+="uaccess"

LABEL="kc_end"
